pipeline {
    agent any

    stages {
        stage("Checkout Code") {
            steps {
                git branch: 'main', url: 'https://github.com/antonioconac/web-automation-selenium.git'
            }
        }

        stage("Install Dependencies") {
            steps {
                bat 'python -m pip install --upgrade pip'
                bat 'pip install -r requirements.txt'
            }
        }

        stage("Test Basic Functionality") {
            steps {
                bat 'pytest tests\\test_basic_functionality.py'
            }
        }

        stage("Test Complete Flow") {
            steps {
                bat 'pytest tests\\test_complete_flow.py'
            }
        }

        stage("Test Errors for Login") {
            steps{
                bat 'pytest tests\\test_problematic_users.py'
            }
        }
    }
    post {
        always {
            echo "Tests finished"
        }
    }
}
