pipeline {
    agent any

    stages {
        stage("Checkout Code") {
            steps {
                git branch: 'main', url: 'https://github.com/antonioconac/web-automation-selenium.git'
            }
        }

        stage("Install Dependencies") {
            steps {
                bat 'python -m pip install --upgrade pip'
                bat 'pip install -r requirements.txt'
            }
        }

        stage("Run Tests") {
            steps {
                bat 'pytest'
        }
    }
}
    post {
        always {
            archiveArtifacts artifacts: 'report.html', fingerprint: true
        }
    }
}
